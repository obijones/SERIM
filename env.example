# .env — Brand Protection Monitor
# Copy to .env in your project root and fill in values
# Never commit .env to git — add it to .gitignore

# -----------------------------------------------------------------------
# Paths  (ALL REQUIRED — serp_monitor.py has no built-in defaults for these
#         and exits at startup if any is unset. LOG_FILE is set further down.)
# -----------------------------------------------------------------------

# Persistent browser profile — created by setup_profile.py (run once)
PROFILE_DIR=/path/to/project/browser_profile

# Evidence output directory (screenshots, DOM snapshots, JSON records)
EVIDENCE_DIR=/path/to/project/evidence

# Analyst triage list — benign third-party domains suppressed from alerts
TRIAGE_FILE=/path/to/project/triaged_domains.json

# SQLite campaign store — created automatically on first run, no setup needed.
# The parent directory must exist and be writable.
FINDINGS_DB=/path/to/project/findings.db

# -----------------------------------------------------------------------
# Known-legitimate institution registry (OPTIONAL — unlike the paths above)
# -----------------------------------------------------------------------
# The brand terms are generic, so real licensed financial institutions bid and
# rank on them. They are not offences, and this registry keeps them out of the
# report metrics while still collecting them.
#
# Unset is safe: every non-infringing finding is then reported as UNREVIEWED —
# visible, not silently cleared. A registry can only ever mark something
# legitimate by POSITIVE membership, so a missing or broken file can never hide
# a threat. Created on first use by --mark-legitimate.
#
# Distinct from TRIAGE_FILE: triage is a per-incident note on one exact host;
# this is a durable statement about an organization, records why it was trusted,
# and matches subdomains. Distinct from ALLOWLIST_DOMAINS, which means "we own
# this domain" — a competitor is not ours.
FI_REGISTRY_FILE=/path/to/project/known_fi.json

# -----------------------------------------------------------------------
# Google rate-block cooldown (optional — sensible defaults if unset)
# -----------------------------------------------------------------------
# When Google serves its /sorry "unusual traffic" reCAPTCHA, the monitor
# pauses Google (Bing keeps running) and waits before probing again, backing
# off exponentially if it is still blocked. Continuing to query while blocked
# only sustains the block, so these keep the IP quiet enough to recover.
#   GOOGLE_COOLDOWN_BASE_MIN  first pause, in minutes (default 180 = 3h)
#   GOOGLE_COOLDOWN_MAX_MIN   backoff cap, in minutes (default 720 = 12h)
GOOGLE_COOLDOWN_BASE_MIN=180
GOOGLE_COOLDOWN_MAX_MIN=720
# Where the cooldown timer is persisted (survives restarts). Defaults next to
# FINDINGS_DB; set only if you want it elsewhere.
# COOLDOWN_STATE_FILE=/path/to/project/cooldown_state.json

# -----------------------------------------------------------------------
# Traffic-shaping jitter (optional — used only in --schedule mode)
# -----------------------------------------------------------------------
# A machine-perfect cadence is itself a bot signal. These spread traffic out
# WITHOUT adding request volume. Jitter only moves WHEN runs fire.
#   SCHEDULE_JITTER_FRAC     inter-run interval jitter, as a fraction of the
#                            base interval (0.20 = +/-20%; 0 disables)
#   WITHIN_RUN_JITTER_MIN/MAX  seconds of random gap between brand-term queries
#                            within a run (terms are also shuffled); 0/0 disables
#   GOOGLE_RESUME_JITTER_MIN after a cooldown expires, wait up to this many
#                            minutes before the resume-probe fires
SCHEDULE_JITTER_FRAC=0.20
WITHIN_RUN_JITTER_MIN=20
WITHIN_RUN_JITTER_MAX=40
GOOGLE_RESUME_JITTER_MIN=15

# Log file (REQUIRED — no built-in default; opened at startup)
LOG_FILE=/path/to/project/brand_monitor.log

# -----------------------------------------------------------------------
# SMTP / Mailgun
# -----------------------------------------------------------------------

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASSWORD=your-mailgun-api-key-here
ALERT_FROM=cti-monitor@mg.yourdomain.com
# Multiple recipients: comma-separated, no spaces required
ALERT_TO=analyst1@yourdomain.com,analyst2@yourdomain.com
