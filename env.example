# .env — Brand Protection Monitor
# Copy to .env in your project root and fill in values
# Never commit .env to git — add it to .gitignore

# -----------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------

# Persistent browser profile — created by setup_profile.py (run once)
PROFILE_DIR=/path/to/project/browser_profile

# Evidence output directory (screenshots, DOM snapshots, JSON records)
EVIDENCE_DIR=/path/to/project/evidence

# Analyst triage list — benign third-party domains suppressed from alerts
TRIAGE_FILE=/path/to/project/triaged_domains.json

# Log file
LOG_FILE=/path/to/project/brand_monitor.log

# -----------------------------------------------------------------------
# SMTP / Mailgun
# -----------------------------------------------------------------------

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASSWORD=your-mailgun-api-key-here
ALERT_FROM=cti-monitor@mg.yourdomain.com
# Multiple recipients: comma-separated, no spaces required
ALERT_TO=analyst1@yourdomain.com,analyst2@yourdomain.com
